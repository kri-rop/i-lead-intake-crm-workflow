      "parameters": {
        "jsCode": "const rawText = $json.content?.[0]?.text;\n\nif (!rawText) {\n  return [\n    {\n      json: {\n        parsing_error: true,\n        error_message: \"Claude hat keinen auswertbaren Text geliefert\"\n      }\n    }\n  ];\n}\n\ntry {\nconst cleanedText = rawText\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\n  const parsedData = JSON.parse(cleanedText);\n\n  return [\n    {\n      json: {\n        ...parsedData,\n        parsing_error: false\n      }\n    }\n  ];\n} catch (error) {\n  return [\n    {\n      json: {\n        parsing_error: true,\n        error_message: error.message,\n        raw_response: rawText\n      }\n    }\n  ];\n}"
      },
